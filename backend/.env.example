# DropVid Backend Configuration
# Copy to .env and fill in values

# Redis
REDIS_URL=redis://redis:6379/0

# Downloads
DOWNLOAD_DIR=/app/downloads
MAX_FILE_AGE_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Worker
CELERY_CONCURRENCY=4
MAX_RETRIES=3
